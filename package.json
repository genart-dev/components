{
  "name": "@genart-dev/components",
  "version": "0.1.0",
  "description": "Reusable sketch components for the .genart ecosystem",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "author": {
    "name": "genart.dev",
    "email": "support@genart.dev",
    "url": "https://genart.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/genart-dev/components.git"
  },
  "homepage": "https://genart.dev",
  "keywords": [
    "genart",
    "generative-art",
    "components",
    "prng",
    "noise",
    "easing",
    "glsl"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "tsx validate.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@genart-dev/format": "^0.2.0"
  },
  "pnpm": {
    "overrides": {
      "@genart-dev/format": "link:../format"
    }
  },
  "devDependencies": {
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
